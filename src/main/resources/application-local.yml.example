# ==================== 本地开发配置模板 ====================
# 使用方式:
#   1. 复制此文件为 application-local.yml
#   2. 填入真实的 API Key
#   3. 启动时激活 local profile: --spring.profiles.active=local
#
# IDEA 启动配置: Run → Edit Configurations → Active profiles → local

# 覆盖 application.yml 中的敏感配置
app:
  ai:
    chat:
      api-key: your-chat-api-key-here
    embedding:
      api-key: your-embedding-api-key-here